<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.takeway.firstspringboot.mapper.OrderItemMapper">

    <resultMap id="BaseResultMap" type="com.example.takeway.firstspringboot.entity.OrderItem">
            <id property="id" column="id" />
            <result property="orderNo" column="order_no" />
            <result property="productId" column="product_id" />
            <result property="quantity" column="quantity" />
            <result property="snapshotPrice" column="snapshot_price" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
            <result property="productName" column="product_name" />
    </resultMap>

    <sql id="Base_Column_List">
        id,order_no,product_id,quantity,snapshot_price,create_time,
        update_time,product_name
    </sql>
</mapper>
